# This is Git's per-user configuration file.
[user]
# Please adapt and uncomment the following lines:
name = Daniel Vieites
email = dvieitest@gmail.com
[init]
    defaultBranch = main

[core]
    pager = diff-so-fancy | less --tabs=4 -RF

[diff-so-fancy]
    stripLeadingSymbols = false
    shortHeaders = true
