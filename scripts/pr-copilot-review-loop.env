# Config for pr-copilot-review-loop.sh
# The script runs fine without this file, using the built-in defaults shown here.

# Which agent drives the loop: pi | opencode
PR_COPILOT_LOOP_AGENT=pi

# Model for the pi backend (has a built-in default)
PR_COPILOT_LOOP_PI_MODEL=openai-codex/gpt-5.5

# Model for the opencode backend — REQUIRED when PR_COPILOT_LOOP_AGENT=opencode (no default).
# Run `opencode models` to list options, e.g. opencode/gpt-5.3-codex
PR_COPILOT_LOOP_OPENCODE_MODEL=

# Reasoning effort, shared by both backends (pi --thinking / opencode --variant).
PR_COPILOT_LOOP_MODEL_THINKING=high
